{
    "schemaVersion": "1.9.0",
    "resources": {
        "linux": {
            "user": {
                "groups": ["pipewire"]
            }
        },
        "dbus": {
            "requiredMethods": [
                "com.axis.HTTPConf1.VAPIXServiceAccounts1.GetCredentials"
            ]
        }
    },
    "acapPackageConf": {
        "setup": {
            "friendlyName": "Axis C6110 Audio Extensions",
            "appName": "audio_control",
            "vendor": "MRDN Labs",
            "embeddedSdkVersion": "3.0",
            "runMode": "respawn",
            "version": "2.0.0"
        },
        "configuration": {
            "settingPage": "index.html",
            "paramConfig": [
                {
                    "name": "EnableSpeakerGuard",
                    "type": "bool",
                    "default": "yes"
                },
                {
                    "name": "EnableAudioForward",
                    "type": "bool",
                    "default": "yes"
                },
                {
                    "name": "EnableDualAudio",
                    "type": "bool",
                    "default": "no"
                },
                {
                    "name": "RemoteIP",
                    "type": "string",
                    "default": ""
                },
                {
                    "name": "RemoteUser",
                    "type": "string",
                    "default": ""
                },
                {
                    "name": "RemotePass",
                    "type": "string",
                    "default": ""
                },
                {
                    "name": "ActiveMode",
                    "type": "string",
                    "default": "instructor"
                },
                {
                    "name": "HeadphoneNodeName",
                    "type": "string",
                    "default": "AudioDevice0Output0"
                },
                {
                    "name": "SpeakerNodeName",
                    "type": "string",
                    "default": "AudioDevice0Output1"
                },
                {
                    "name": "CaptureNodeName",
                    "type": "string",
                    "default": "AudioDevice0Outputs"
                }
            ]
        }
    }
}
